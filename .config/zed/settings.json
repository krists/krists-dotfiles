// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "auto_update": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
  },
  "close_on_file_delete": true,
  "session": {
    "trust_all_worktrees": true,
  },
  "restore_on_startup": "launchpad",
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "gutter": {
    "runnables": false,
    "breakpoints": false,
    "min_line_number_digits": 3,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "project_panel": {
    "drag_and_drop": true,
    "hide_hidden": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "agent": {
    "enabled": false,
  },
  "disable_ai": true,
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "addonSettings": {
          "Ruby LSP Rails": {
            "enablePendingMigrationsPrompt": false,
          },
        },
      },
    },
  },
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop"],
    },
    "HTML+ERB": {
      "language_servers": ["herb", "!ruby-lsp", "..."],
    },
  },
}
